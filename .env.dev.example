# Workspace .env — DEVELOPMENT TEMPLATE.
#
# Copy to .env for a local stack:
#   cp .env.dev.example .env
#
# Pairs with docker-compose.override.yml (auto-merged by `docker compose up`).
# For production, use .env.prod.example instead — it sets COMPOSE_FILE so the
# dev override is skipped on the VPS. See docs/DEPLOYMENT.md.
#
# Never commit .env.

# ---- nginx ----
NGINX_SERVER_NAME=localhost

# TLS overlay. Off in dev — the proxy serves http://localhost:8080.
# In prod (see .env.prod.example), set NGINX_TLS_ENABLED=true and mount
# real certs at the paths below (defaults point to
# ./nginx/certs/{fullchain,privkey,chain}.pem, which is bind-mounted into
# the container by docker-compose.yml). See nginx/README.md "Production
# TLS" for the Let's Encrypt + certbot flow.
NGINX_TLS_ENABLED=false
# NGINX_TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
# NGINX_TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
# NGINX_TLS_TRUSTED_CHAIN_PATH=/etc/nginx/certs/chain.pem

# ---- BFF ----
# Public base URL — what the user's browser sees during the OAuth redirect.
# Must match a Keycloak "Valid Redirect URI" of the form
# ${PUBLIC_BASE_URL}/auth/callback. Pick the one that matches where your
# browser actually runs:
#   Android emulator  → http://10.0.2.2:8080   (10.0.2.2 = host's localhost)
#   iOS simulator     → http://localhost:8080
#   Desktop browser   → http://localhost:8080
PUBLIC_BASE_URL=http://10.0.2.2:8080
NODE_ENV=development
LOG_LEVEL=info

# ---- Keycloak (super-app-bff confidential client in realm `pangkalpinang`) ----
KC_ISSUER=https://sso.pangkalpinangkota.go.id/realms/pangkalpinang
KC_CLIENT_ID=super-app-bff
# Set this from the Keycloak admin UI → Clients → super-app-bff → Credentials.
KC_CLIENT_SECRET=
KC_SCOPES=openid profile email

# ---- Trust boundary: which front-end app identifiers the BFF accepts ----
# These are NOT relayed to Keycloak; they're the BFF's own allowlist.
ALLOWED_APP_CLIENTS=super-app-eco

# Exact-match allowlist of deeplink redirect URIs the BFF will hand `code` to.
ALLOWED_APP_REDIRECT_URIS=id.go.pangkalpinangkota.smartapptest:/oauth2redirect

# ---- TTLs (seconds) ----
SESSION_TTL_SECONDS=2592000
AUTHSTATE_TTL_SECONDS=600
BFFCODE_TTL_SECONDS=300

# ---- CORS — only matters if a web client is added later ----
CORS_ORIGINS=

# ---- Internal JWT (BFF mints, Kong validates with public key only) ----
# RS256 asymmetric — BFF holds the private key; Kong reads only the matching
# public key from kong/kong.yml. See bff/docs/IMPROVEMENT_PLAN.md §2.2 for why.
# Generate a fresh dev keypair with:
#   cd bff && npm run gen:keys
# It writes PEMs to bff/keys/, prints base64 values to paste here, and prints
# the public PEM to paste into kong/kong.yml under jwt_secrets.
BFF_INTERNAL_JWT_ALG=RS256
# kid naming: `dev-*` for committed development keys, `prod-*` for the
# key supplied by the prod secrets manager. The `dev-` prefix is
# load-bearing — it makes it obvious in a code review (and in any log)
# that a dev keypair has no business being in front of real users.
BFF_INTERNAL_JWT_ACTIVE_KID=dev-v1
# base64-encoded PKCS#8 PEM
BFF_INTERNAL_JWT_PRIVATE_KEY=
# JSON: [{"kid":"dev-v1","pem":"<base64 SPKI PEM>"}, ...]
# Include every kid Kong currently accepts (for rotation overlap).
BFF_INTERNAL_JWT_PUBLIC_KEYS=
BFF_INTERNAL_JWT_TTL_SECONDS=300
BFF_INTERNAL_JWT_ISSUER=super-app-bff
BFF_INTERNAL_JWT_AUDIENCE=super-app-services
