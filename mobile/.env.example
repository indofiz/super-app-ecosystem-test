# BFF (Backend for Frontend) — the ONLY auth endpoint the app talks to.
# In the workspace stack, nginx fronts the BFF on port 8080. The BFF itself
# is NOT exposed to the host. Set this to nginx, not the BFF directly.
#
#   Android emulator: http://10.0.2.2:8080  (10.0.2.2 = host's localhost)
#   iOS simulator:    http://localhost:8080
#   Physical device:  http://<your-laptop-LAN-ip>:8080
#   Production:       https://<your-public-host>
BFF_BASE_URL=http://10.0.2.2:8080

# Logical client_id the BFF accepts (allowlisted in workspace .env's
# ALLOWED_APP_CLIENTS). NOT registered in Keycloak.
OAUTH_CLIENT_ID=super-app-eco

# Deeplink redirect URI. Must be in the BFF's ALLOWED_APP_REDIRECT_URIS and
# match the Android `appAuthRedirectScheme` placeholder.
OAUTH_REDIRECT_URI=id.go.pangkalpinangkota.smartapptest:/oauth2redirect

# OAuth scopes requested via the BFF.
OAUTH_SCOPES=openid profile email

# Toggle the in-app mock auth repository (true = bypass BFF for local dev).
# Set to `false` once the BFF is reachable AND the Keycloak `super-app-bff`
# client is registered with a real client_secret.
USE_MOCK_AUTH=true

# Allow plain-HTTP OAuth redirects. REQUIRED for local dev (BFF on :8080
# without TLS). MUST be `false` in production.
ALLOW_INSECURE_CONNECTIONS=true

# Redacted pretty Dio logger. When `true` AND the build is a debug build,
# every BFF/Kong call is logged as a boxed request/response panel via
# `dart:developer` (DevTools / `adb logcat`).
#
# It is SAFE because the logger never sees the live request: it formats a
# redacted *clone* in which Authorization/bearer, access/refresh/id
# tokens, OTP `code`, `password`, `phone`, and the BFF's
# `error_description` are masked as «redacted» (audit-004 H-03 stays
# intact). The live request is byte-for-byte untouched.
#
# Force-disabled in release builds regardless of this value (AppConfig
# dead-code-eliminates the `true` branch). Keep `false` by default —
# it is opt-in per developer and noisy. NEVER `true` in production.
HTTP_VERBOSE_LOG=false
