# Workspace .env — PRODUCTION TEMPLATE.
#
# Copy to .env on the VPS, then chmod 600:
#   cp .env.prod.example .env
#   chmod 600 .env
#
# Every <PLACEHOLDER> below MUST be filled. The BFF will fail to start
# (Zod validation error) if any required secret is left blank.
#
# Walks step-by-step through this file:  docs/DEPLOYMENT.md §7
# Never commit .env.

# ---- Compose ----
# Tells `docker compose` to read ONLY docker-compose.yml — the dev-only
# docker-compose.override.yml (which exposes Redis/BFF/sample-service to
# the host) is intentionally skipped in prod. Do not remove this line.
COMPOSE_FILE=docker-compose.yml

# ---- nginx ----
NGINX_SERVER_NAME=<PUBLIC_HOSTNAME>            # e.g. api.pangkalpinangkota.go.id

# TLS overlay.
#   First boot of §9 in DEPLOYMENT.md: keep NGINX_TLS_ENABLED=false so
#   Let's Encrypt's HTTP-01 challenge can reach :80.
#   After certs land (§11): flip to true and recreate nginx.
NGINX_TLS_ENABLED=false
# Defaults align with the bind-mount in docker-compose.yml — leave commented
# unless you need to override the in-container path.
# NGINX_TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
# NGINX_TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
# NGINX_TLS_TRUSTED_CHAIN_PATH=/etc/nginx/certs/chain.pem

# ---- BFF ----
# Must match the Keycloak Valid Redirect URI added in §12 of DEPLOYMENT.md.
PUBLIC_BASE_URL=https://<PUBLIC_HOSTNAME>
NODE_ENV=production
LOG_LEVEL=info

# ---- Keycloak (super-app-bff confidential client in realm `pangkalpinang`) ----
KC_ISSUER=https://sso.pangkalpinangkota.go.id/realms/pangkalpinang
KC_CLIENT_ID=super-app-bff
# Paste from Keycloak admin → Clients → super-app-bff → Credentials (§6.2).
KC_CLIENT_SECRET=<PASTE_FROM_KEYCLOAK>
KC_SCOPES=openid profile email

# ---- Trust boundary: which front-end app identifiers the BFF accepts ----
ALLOWED_APP_CLIENTS=super-app-eco

# Exact-match allowlist of deeplink redirect URIs the BFF will hand `code` to.
ALLOWED_APP_REDIRECT_URIS=id.go.pangkalpinangkota.smartapptest:/oauth2redirect

# ---- TTLs (seconds) — defaults are fine for prod ----
SESSION_TTL_SECONDS=2592000
AUTHSTATE_TTL_SECONDS=600
BFFCODE_TTL_SECONDS=300

# ---- CORS — only matters if a web client is added later ----
CORS_ORIGINS=

# ---- Internal JWT (BFF mints, Kong validates with public key only) ----
# RS256. Mint the prod keypair ON THE VPS, never on a laptop:
#   cd ~/super-app/bff && node scripts/generate-dev-keys.mjs prod-v1
# The script prints the three values to paste below + the public PEM to
# inline into kong/kong.yml's consumers[].jwt_secrets[].rsa_public_key
# block (under a `prod-v1` kid). See DEPLOYMENT.md §5 and §8.
# The PEM lives in kong.yml directly because Kong 3.x DB-less rejects
# `{vault://env/...}` references on consumer credentials at parse time.
BFF_INTERNAL_JWT_ALG=RS256
# `prod-` prefix is load-bearing: if a `kid=dev-*` ever appears in a prod
# log, somebody has cross-contaminated environments.
BFF_INTERNAL_JWT_ACTIVE_KID=prod-v1
# base64-encoded PKCS#8 PEM (from the key-gen script).
BFF_INTERNAL_JWT_PRIVATE_KEY=<PASTE_FROM_KEYGEN>
# JSON: [{"kid":"prod-v1","pem":"<base64 SPKI PEM>"}, ...]
# Include every kid Kong currently accepts (for rotation overlap).
BFF_INTERNAL_JWT_PUBLIC_KEYS=<PASTE_FROM_KEYGEN>
BFF_INTERNAL_JWT_TTL_SECONDS=300
BFF_INTERNAL_JWT_ISSUER=super-app-bff
BFF_INTERNAL_JWT_AUDIENCE=super-app-services
